// Firestore Security Rules for Deferred Deep Links
// Deploy to Firebase Console > Firestore > Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deferred Deep Links collection
    match /deferredDeepLinks/{linkId} {
      // Anyone can create (web landing page)
      allow create: if request.resource.data.keys().hasAll(['fingerprint', 'deepLinkUrl', 'createdAt', 'expiresAt'])
                    && request.resource.data.fingerprint is string
                    && request.resource.data.deepLinkUrl is string;

      // Anyone can read and delete (mobile app retrieval)
      allow read, delete: if true;

      // No updates allowed
      allow update: if false;
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
