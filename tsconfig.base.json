{
    "compileOnSave": false,
    "compilerOptions": {
        "composite": true,
        "declarationMap": true,
        "emitDeclarationOnly": true,
        "importHelpers": true,
        "isolatedModules": true,
        "lib": ["es2022", "dom"],
        "module": "esnext",
        "moduleResolution": "bundler",
        "noEmitOnError": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitOverride": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "es2022",
        "customConditions": ["@chatic/source"],
        "rootDir": ".",
        "sourceMap": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "baseUrl": ".",
        "paths": {
            "@chatic/app-messages": ["libs/app-messages/src/index.ts"],
            "@chatic/assets": ["assets/src/index.ts"],
            "@chatic/auth": ["libs/auth/src/index.ts"],
            "@chatic/channels": ["libs/channels/src/index.ts"],
            "@chatic/chats": ["libs/chats/src/index.ts"],
            "@chatic/device-utils": ["libs/device-utils/src/index.ts"],
            "@chatic/lib/utils": ["libs/ui-kit/src/utils/index.ts"],
            "@chatic/places": ["libs/places/src/index.ts"],
            "@chatic/pouches": ["libs/pouches/src/index.ts"],
            "@chatic/shared": ["libs/shared/src/index.ts"],
            "@chatic/socket": ["libs/socket/src/index.ts"],
            "@chatic/theme": ["libs/theme/src/index.ts"],
            "@chatic/ui-kit": ["libs/ui-kit/src/index.ts"],
            "@chatic/ui-kit/*": ["libs/ui-kit/src/*"],
            "@chatic/users": ["libs/users/src/index.ts"],
            "@chatic/web-core": ["libs/web-core/src/index.ts"]
        }
    },
    "exclude": ["node_modules", "tmp"]
}
