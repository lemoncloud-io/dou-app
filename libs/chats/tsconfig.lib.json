{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc",
        "declaration": true,
        "types": ["node", "vite/client"],
        "jsx": "react-jsx"
    },
    "include": ["src/**/*.ts", "src/**/*.tsx"],
    "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"],
    "references": [
        {
            "path": "../shared/tsconfig.lib.json"
        },
        {
            "path": "../web-core/tsconfig.lib.json"
        }
    ]
